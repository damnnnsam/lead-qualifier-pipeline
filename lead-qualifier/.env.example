# Required — set via `fly secrets set` for production
DEEPSEEK_API_KEY=
SERPER_API_KEY=
API_KEY=

# Proxy — BrightData HTTP proxy URL (datacenter or residential)
# Format: http://brd-customer-ACCOUNT-zone-ZONE:PASSWORD@brd.superproxy.io:33335
BRIGHTDATA_PROXY=

# LLM settings
LLM_PROVIDER=deepseek
LLM_CONCURRENCY=50

# Scraper settings
SCRAPE_CONCURRENCY=50

# API settings
MAX_CONCURRENT_JOBS=16
MAX_DOMAINS_PER_REQUEST=5000
JOB_TIMEOUT_SECONDS=1200

# Optional — only needed if LLM_PROVIDER=claude
# ANTHROPIC_API_KEY=
